{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@aircraft/validators/*": ["./src*"],
      "@aircraft/validators": ["./src/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
