{
  "name": "electron.initialencounter.aircraft",
  "version": "0.10.2",
  "description": "Aircraft electron app",
  "author": {
    "name": "InitialEncounter"
  },
  "main": "dist-electron/main/index.js",
  "preload": "dist-electron/preload/index.js",
  "scripts": {
    "start": "chcp 65001 && vite -c vite.electron.config.ts",
    "package": "vue-tsc --noEmit && vite -c vite.electron.config.ts build && electron-forge package",
    "build": "vue-tsc --noEmit && vite -c vite.electron.config.ts build && electron-forge make"
  },
  "config": {
    "forge": "./forge.config.ts"
  },
  "devDependencies": {
    "@aircraft/renderer": "workspace:*",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^3.1.0",
    "@types/auto-launch": "^5.0.5",
    "@types/cors": "^2.8.19",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__multer": "^2.0.8",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "aircraft-rs": "workspace:*",
    "auto-launch": "^5.0.6",
    "cordis": "^3.18.1",
    "electron": "38.3.0",
    "electron-builder": "^26.4.2",
    "electron-wix-msi": "^5.1.3",
    "koa-compose": "^4.2.0",
    "multer": "^1.4.5-lts.2",
    "typescript": "^6.0.0-dev.20260313",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue": "^3.6.0-beta.7",
    "vue-tsc": "^3.2.5"
  }
}